{
    "annotations": {
        "list": []
    },
    "description": "JARVIS AI Agent — Production Monitoring Dashboard",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "title": "Request Rate (req/s)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(jarvis_requests_total[5m])",
                    "legendFormat": "{{method}} {{endpoint}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth",
                        "fillOpacity": 20,
                        "gradientMode": "scheme"
                    }
                }
            }
        },
        {
            "title": "Error Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(jarvis_errors_total[5m])",
                    "legendFormat": "{{error_type}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "drawStyle": "bars",
                        "fillOpacity": 80
                    },
                    "color": {
                        "mode": "palette-classic"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 5
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Response Latency (p50/p95/p99)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, rate(jarvis_request_duration_seconds_bucket[5m]))",
                    "legendFormat": "p50"
                },
                {
                    "expr": "histogram_quantile(0.95, rate(jarvis_request_duration_seconds_bucket[5m]))",
                    "legendFormat": "p95"
                },
                {
                    "expr": "histogram_quantile(0.99, rate(jarvis_request_duration_seconds_bucket[5m]))",
                    "legendFormat": "p99"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth"
                    }
                }
            }
        },
        {
            "title": "Active Sessions",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 8
            },
            "targets": [
                {
                    "expr": "jarvis_active_sessions"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 50
                            },
                            {
                                "color": "red",
                                "value": 100
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Memory Usage",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 8
            },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes / 1024 / 1024"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "decmbytes",
                    "max": 2048,
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 1024
                            },
                            {
                                "color": "red",
                                "value": 1792
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Channel Health",
            "type": "table",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 12
            },
            "targets": [
                {
                    "expr": "jarvis_channel_status",
                    "format": "table",
                    "instant": true
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "align": "center"
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "status"
                        },
                        "properties": [
                            {
                                "id": "custom.displayMode",
                                "value": "color-background"
                            }
                        ]
                    }
                ]
            }
        },
        {
            "title": "LLM Token Usage",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "targets": [
                {
                    "expr": "rate(jarvis_llm_tokens_total{type=\"input\"}[5m])",
                    "legendFormat": "Input tokens/s"
                },
                {
                    "expr": "rate(jarvis_llm_tokens_total{type=\"output\"}[5m])",
                    "legendFormat": "Output tokens/s"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 30,
                        "stacking": {
                            "mode": "normal"
                        }
                    }
                }
            }
        },
        {
            "title": "Sandbox Execution Time",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(jarvis_sandbox_duration_seconds_bucket[5m]))",
                    "legendFormat": "p95 sandbox execution"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                }
            }
        },
        {
            "title": "Rate Limit Rejections",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 24
            },
            "targets": [
                {
                    "expr": "rate(jarvis_rate_limit_rejected_total[5m])",
                    "legendFormat": "{{rule}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "drawStyle": "bars",
                        "fillOpacity": 80
                    },
                    "color": {
                        "fixedColor": "orange",
                        "mode": "fixed"
                    }
                }
            }
        },
        {
            "title": "Plugin Execution",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 24
            },
            "targets": [
                {
                    "expr": "rate(jarvis_plugin_calls_total[5m])",
                    "legendFormat": "{{plugin}}.{{tool}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth"
                    }
                }
            }
        }
    ],
    "schemaVersion": 39,
    "tags": [
        "jarvis",
        "jarvis",
        "production"
    ],
    "templating": {
        "list": [
            {
                "name": "datasource",
                "type": "datasource",
                "query": "jarvis"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "browser",
    "title": "JARVIS — Production Dashboard",
    "uid": "jarvis-prod",
    "version": 1
}