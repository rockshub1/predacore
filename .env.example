# PredaCore environment configuration

# Shared service endpoints
CSC_ADDRESS=localhost:50052
DAF_ADDRESS=localhost:50055
WIL_ADDRESS=localhost:50054
EGM_ADDRESS=localhost:50053
KN_ADDRESS=localhost:50051

# Metrics ports
CSC_METRICS_PORT=8010
DAF_METRICS_PORT=8012
WIL_METRICS_PORT=8011

# API Gateway configuration
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
REDIS_URL=redis://localhost:6379/0

# Planner toggles
USE_MCTS_PLANNER=0
MCTS_BRANCHES=3
MCTS_MAX_DEPTH=3
MCTS_BUDGET=16

# WIL approvals / orchestration
APPROVALS_REQUIRED=0
ORCH_URL=http://localhost:8000

# LLM / embedding providers (set if using external APIs)
LLM_PROVIDER=gemini-cli
LLM_MODEL=gemini-3-pro-preview
LLM_FALLBACK_MODELS=gemini-3-flash-preview,gemini-2.5-pro
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=
EMBED_PROVIDER=auto
EMBED_MODEL=models/gemini-embedding-001

# PredaCore runtime memory grounding (persistent memory -> system prompt)
PREDACORE_MEMORY_PROMPT_TOP_K=5
PREDACORE_MEMORY_PROMPT_MAX_CHARS=1800

# Playwright (set to 1 to enable browser automation)
ENABLE_PLAYWRIGHT=1

# Desktop control (macOS)
PREDACORE_ENABLE_DESKTOP_CONTROL=1
# Backend order: native (PyObjC) first, then legacy fallback
PREDACORE_DESKTOP_BACKEND=native,legacy
# Optional allow-list (comma-separated app names, leave empty for unrestricted)
PREDACORE_DESKTOP_ALLOWED_APPS=

# OpenClaw bridge + skills import
PREDACORE_ENABLE_OPENCLAW_BRIDGE=0
OPENCLAW_BRIDGE_URL=http://127.0.0.1:19001
OPENCLAW_BRIDGE_TASK_PATH=/v1/responses
OPENCLAW_BRIDGE_STATUS_PATH=/v1/tasks/{task_id}
OPENCLAW_BRIDGE_MODEL=openclaw
OPENCLAW_BRIDGE_AGENT_ID=main
OPENCLAW_BRIDGE_API_KEY=
OPENCLAW_BRIDGE_TIMEOUT=180
OPENCLAW_BRIDGE_VERIFY_TLS=0
OPENCLAW_SKILLS_DIR=external/openclaw/skills
OPENCLAW_AUTO_IMPORT_SKILLS=1
