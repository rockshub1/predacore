        {"expr": "histogram_quantile(0.5, rate(csc_plan_latency_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.9, rate(csc_plan_latency_seconds_bucket[5m]))", "legendFormat": "p90"},
